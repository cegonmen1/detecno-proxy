# ---------------------------------------------------------------------------
# Espejo Detecno - un solo proceso atiende QAS y PRD
# Copiar a .env y ajustar. NUNCA commitear .env.
# ---------------------------------------------------------------------------

# Puerto unico del espejo (lo que SAP consume)
PORT=3000

# Validar el certificado del PAC al reenviar (true recomendado).
PAC_TLS_REJECT_UNAUTHORIZED=true

# ---------------------------------------------------------------------------
# CATALOGO DE OPERACIONES DEL PAC (18 totales, tal como las expone el WSDL)
# ---------------------------------------------------------------------------
# Liberacion gradual: SAP siempre VE las 18 (estan en el WSDL), pero el espejo
# solo deja pasar al PAC las que esten en QAS_ALLOWED_OPS / PRD_ALLOWED_OPS.
# Las demas reciben un SOAP Fault 403 "operacion no habilitada".
# Para liberar otra: copia su nombre EXACTO a la linea ALLOWED_OPS (separado
# por coma, sin espacios) y reinicia el servicio. VACIO = se habilitan TODAS.
#
#   CFDI 4.0:
#     ComprobanteGenerarSAT40            timbrar CFDI 4.0 sellado SAT   <-- liberada
#     ComprobanteGenerar40               timbrar CFDI 4.0
#     ComprobanteBuscar40                buscar CFDI 4.0 por facturaId
#     ComprobanteBuscarUUID40            buscar CFDI 4.0 por UUID
#     Comprobante_BuscarPdf40            obtener PDF del CFDI 4.0
#     ComprobanteCancelar40              cancelar CFDI 4.0 por facturaId
#     Comprobante_CancelarUUID40         cancelar CFDI 4.0 por UUID
#     ConsultafacturaId40                consultar facturaId (serie/folio/RFC)
#   CFDI 3.3:
#     ComprobanteBuscar33                buscar CFDI 3.3 por facturaId
#     ComprobanteBuscarUUID33            buscar CFDI 3.3 por UUID
#   Retenciones:
#     ComprobanteGenerarRetencion20      timbrar Retencion 2.0
#     ComprobanteBuscarRetencion20       buscar Retencion 2.0
#     Comprobante_BuscarPdfRetencion20   PDF de Retencion 2.0
#     ComprobanteRetencionCancelar20     cancelar Retencion 2.0
#     ComprobanteBuscarRetencion10       buscar Retencion 1.0
#   Cancelacion / busqueda externa:
#     ComprobanteCancelarExterna         cancelar externa (UUID/RFC/total)
#     ComprobanteBuscarExterna           buscar externa por UUID
#   Diagnostico:
#     Prueba                             ping del servicio
# ---------------------------------------------------------------------------

# --- QAS (pruebas) ---  ruta del espejo: /qas/Detecno.svc
QAS_ENABLED=true
QAS_PAC_URL=https://detecno-factura-electronica.com/Emision/cfdiWcfEmisionServicio40_Demo/Detecno.svc
# URL publica tal como SAP ve al espejo (cambiar localhost por el host/IP real al desplegar)
QAS_PUBLIC_URL=http://localhost:3000/qas/Detecno.svc
# Liberacion gradual: operaciones habilitadas (coma, sin espacios). VACIO = todas.
# Ir agregando del catalogo de arriba conforme el cliente apruebe cada metodo.
QAS_ALLOWED_OPS=ComprobanteGenerarSAT40
# Auto-inyeccion de WS-Addressing si SAP no la manda (transparencia). Default true.
QAS_WSA_AUTOINJECT=true
# Quita la WS-SecurityPolicy HTTPS del WSDL servido a SAP. Necesario al publicar en
# HTTP plano: sin esto SOAMANAGER falla con "No Service found in WSDL". Default true.
QAS_WSDL_STRIP_POLICY=true

# --- PRD (produccion) ---  ruta del espejo: /prd/Detecno.svc
# OJO: timbrar en PRD genera CFDI reales y consume creditos. Encender solo con licencia productiva.
PRD_ENABLED=false
PRD_PAC_URL=https://genera.emisiondetecno.mx/Detecno/WebService_EmisionServicio40/Detecno.svc
PRD_PUBLIC_URL=http://localhost:3000/prd/Detecno.svc
# Liberacion gradual en PRD (mismo catalogo de operaciones que QAS, arriba). VACIO = todas.
PRD_ALLOWED_OPS=ComprobanteGenerarSAT40
PRD_WSA_AUTOINJECT=true
PRD_WSDL_STRIP_POLICY=true
